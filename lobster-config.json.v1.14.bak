  "catalyst": {
    "lookback_days": 7,
    "score_boost_days": 14,
    "fallout_lookback_days": 10,
    "boost_dim2_sector": true,
    "fallout_track_cooldown": 5,
    "_note": "催化学分：lookback_days内近期催化提升优先级；fallout_lookback_days无反应→标记落空评估",
    "scoring_weights": {
      "fact_strength": 0.25,
      "expectation_diff": 0.3,
      "heat": 0.1,
      "payoff_period": 0.2,
      "tradability": 0.15,
      "_note": "五维评分权重（可进化）：F×25% + E×30% + H×10% + P×20% + T×15%",
      "_evolvable": true
    },
    "grade_thresholds": {
      "S": 90,
      "A": 80,
      "B": 65,
      "C": 50,
      "D": 0,
      "_note": "催化剂等级阈值（可进化）：≥90=S, ≥80=A, ≥65=B, ≥50=C, <50=D",
      "_evolvable": true
    },
    "heat_penalty": {
      "enabled": true,
      "threshold": 4,
      "penalty_pct": 0.2,
      "_note": "热度降权：heat≥4时总分×0.8；可进化调整threshold和penalty_pct",
      "_evolvable": true
    },
    "grade_action": {
      "S": "strong_buy",
      "A": "buy",
      "B": "observe",
      "C": "watch_only",
      "D": "block",
      "_note": "催化剂等级对应动作：S=强买, A=买, B=观察, C=只看, D=禁止",
      "_evolvable": true
    }
  },
  "stop_loss": {
    "1.0": {
      "hard_stop_pct": -7,
      "time_stop_days": 3,
      "time_stop_condition": "not_zt",
      "_note": "超短纪律：买入价-7%硬止损（2026-06-09从-5%放宽，给日内波动空间）；第3日未涨停时间止损"
    },
    "2.0": {
      "hard_stop_pct": -7,
      "board_stop_pct": -3,
      "board_stop_condition": "break_ma5",
      "_note": "轮动容错：买入价-7%硬止损；板块跌>3%+个股破MA5则板块止损"
    },
    "3.0": {
      "tech_stop": {
        "volume_break_threshold": 1.5,
        "volume_break_confirm_days": 1,
        "normal_confirm_days": 3,
        "big_break_pct": 3,
        "big_break_confirm_days": 2,
        "_note": "放量下穿（>1.5倍均量）1日确认；缩量3日；大幅>3% 2日确认"
      },
      "logic_stop": "catalyst_failed",
      "holding_enforced": true,
      "_note": "趋势持仓：技术止损（MA5<MA10）+逻辑止损（催化落空）；持有期强制"
    }
  },
  "logic_disprove": {
    "policy_reverse": true,
    "tech_disrupt": true,
    "catalyst_failed_days": 2,
    "track_downgrade": "red_to_green",
    "_note": "逻辑证伪判定：政策逆转/技术颠覆/催化日期过+2日无资金流入/赛道降级"
  },
  "3.0_holding_rules": {
    "tier1_min_days": 5,
    "tier2_min_days": 3,
    "early_exit_condition": "logic_disproved_only",
    "_note": "持有期硬约束：Tier-1≥5日、Tier-2≥3日；期间仅逻辑证伪可提前退出"
  },
  "3.0_exit_rules": {
    "min_satisfied_items": 4,
    "consecutive_days_warning": 2,
    "consecutive_days_confirm": 5,
    "observe_cooldown_days": 30,
    "position_limit_degraded": 1,
    "board_rank_warning": 5,
    "board_rank_exit": 10,
    "_note": "出池阈值：连续2日<4项→预警入观察区；连续5日→确认移出；观察区30日冷静期"
  },
  "3.0_emotion_rules": {
    "enabled": true,
    "辅助_mode": {
      "allow_lowsuck": true,
      "max_position_pct": 10,
      "only_ma10_lowsuck": true,
      "lowsuck_max_pct": 3,
      "no_chase_limit": true
