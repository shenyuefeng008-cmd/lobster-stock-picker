    "unlock_on_drop_to": 3500,
    "melt_below": 1800,
    "inference_zone": {
      "low": 1800,
      "high": 2500,
      "position_ratio": 0.5,
      "_note": "推理区：1800-2500，解锁后仓位减半，需四维评分≥3才解锁"
    },
    "full_activate_above": 2500,
    "full_activate_consecutive_days": 2,
    "_note": "C+B组合：辅助模式允许MA10回踩低吸(≤1成)；情绪回落<3500自动解锁3.0；<1800熔断；1800-2500推理区；>2500严格解锁"
  },
